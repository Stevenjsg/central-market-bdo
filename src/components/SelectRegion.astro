---
interface Props {
  regions: { [key: string]: string };
}
const { regions } = Astro.props;
---

<section
  class="border border-amber-900/60 w-100 h-75 bg-gray-700 rounded-lg flex flex-col justify-center items-center text-white"
>
  <header class="rounded-t-lg bg-gray-800 w-full">
    <h3 class="font-bold text-xl text-center py-4">Selecciona tu región</h3>
  </header>
  <hr class="border border-white/10 w-full" />
  <div class="flex-1 mx-auto flex flex-col justify-center items-center">
    <p class="text-balance font-medium text-center mb-4">
      Selecciona la región en la que desees utilizar el Mercado central.
    </p>
    <select
      class="border-2 border-white/10 py-2 px-4 rounded"
      name="regions"
      id="regions"
    >
      <option class="text-black" selected="true" disabled="true"
        >Selecciona</option
      >
      {
        Object.entries(regions).map(([key, value]) => (
          <option value={key}>{value}</option>
        ))
      }
    </select>
  </div>
  <hr class="border border-white/50 w-full" />
  <footer class="my-4">
    <button
      id="btnRegions"
      disabled
      class="border border-white/15 hover:border-white/30 py-2 px-4 rounded bg-transparent transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
    >
      Continuar
    </button>
  </footer>
</section>
<script>
  import { navigate } from "astro:transitions/client";

  const btn = document.getElementById("btnRegions") as HTMLButtonElement | null;
  const select = document.getElementById("regions") as HTMLSelectElement | null;

  if (btn && select) {
    select.addEventListener("change", () => {
      btn.disabled = false;
      btn.classList.remove("bg-transparent");
      btn.classList.add("bg-white", "text-black");
    });

    btn.addEventListener("click", () => {
      const region = select.value;
      if (region) navigate(`/${region}/store`);
    });
  }
</script>
